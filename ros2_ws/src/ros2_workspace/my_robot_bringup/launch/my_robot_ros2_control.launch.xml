<launch>

    <let name="urdf_path"
        value="$(find-pkg-share my_robot_description)/urdf/my_robot_ros2_control.urdf.xacro"/>

    <let name="rviz_config_path"
        value="$(find-pkg-share my_robot_description)/rviz/my_robot.rviz"/>

    <let name="gazebo_config_path"
        value="$(find-pkg-share my_robot_bringup)/config/gazebo_ros2_control_bridge.yaml"/>

    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description" value="$(command 'xacro $(var urdf_path)')"/>
    </node>

    <node pkg="controller_manager" exec="ros2_control_node">
        <param from="$(find-pkg-share my_robot_bringup)/config/my_robot_controllers.yaml"/>
    </node>

    <node pkg="controller_manager" exec="spawner" args="joint_state_broadcaster"/>

    <node pkg="controller_manager" exec="spawner" args="diff_drive_controller"/>

    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py"> 
        <!-- <arg name="gz_args" value="empty.sdf -r"/> -->
        <arg name="gz_args" value="$(find-pkg-share my_robot_description)/worlds/test_world.sdf -r"/>
    </include>

    <node pkg="ros_gz_sim" exec="create" args="-topic robot_description"/>

    <node pkg="rviz2" exec="rviz2" output="screen" args="-d $(var rviz_config_path)"/>

    <node pkg="ros_gz_bridge" exec="parameter_bridge">
        <param name="config_file" value="$(var gazebo_config_path)"/>
    </node>

</launch>