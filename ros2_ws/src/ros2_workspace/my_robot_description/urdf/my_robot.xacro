<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    
    <xacro:property name="base_length" value="0.6"/>
    <xacro:property name="base_width" value="0.4"/>
    <xacro:property name="base_height" value="0.2"/>
    <xacro:property name="wheel_radius" value="0.1"/>
    <xacro:property name="wheel_length" value="0.05"/>
    <xacro:property name="caster_radius" value="0.05"/>
    
    <link name="base_footprint"/>
    
    <link name="base_link">
        <xacro:inertia_box m="5.0" l="${base_length}" w="${base_width}" h="${base_height}" xyz="0.0 0.0 ${base_height/2}" rpy="0.0 0.0 0.0"/>
        <visual name="">
            <origin xyz="0.0 0.0 ${base_height/2}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 ${base_height/2}" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}"/>
            </geometry>
        </collision>
    </link>

    <xacro:macro name="wheel_link" params="prefix">
        <link name="${prefix}_wheel_link">
            <xacro:inertia_cylinder m="1.0" r="${wheel_radius}" h="${wheel_length}" xyz="0.0 0.0 0.0" rpy="1.57 0.0 0.0"/>
            <visual name="">
                <origin xyz="0.0 0.0 0.0" rpy="1.57 0.0 0.0"/>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
                </geometry>
                <material name="grey"/>
            </visual>
            <collision>
                <origin xyz="0.0 0.0 0.0" rpy="1.57 0.0 0.0"/>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
                </geometry>
            </collision>
        </link>
    </xacro:macro>
    
    <xacro:wheel_link prefix="left"/>
    <xacro:wheel_link prefix="right"/>

    <link name="caster_wheel_link">
        <xacro:inertia_sphere m="0.5" r="${caster_radius}" xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <visual name="">
            <origin xyz="0.0 0.0 0.0" rpy="1.57 0.0 0.0"/>
            <geometry>
                <sphere radius="${caster_radius}"/>
            </geometry>
            <material name="grey"/>
        </visual>
        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="1.57 0.0 0.0"/>
            <geometry>
                <sphere radius="${caster_radius}"/>
            </geometry>
        </collision>
    </link>

    <joint name="base_footprint_joint" type="fixed">
        <origin xyz="0.0 0.0 ${wheel_radius}" rpy="0.0 0.0 0.0"/>
        <parent link="base_footprint"/>
        <child link="base_link"/>
    </joint>

    <joint name="left_wheel_joint" type="continuous">
        <origin xyz="${-base_length/4} ${((base_width/2) + (wheel_length/2))} 0.0" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="left_wheel_link"/>
        <axis xyz="0.0 1.0 0.0"/>
    </joint>

    <joint name="right_wheel_joint" type="continuous">
        <origin xyz="${-base_length/4} ${-((base_width/2) + (wheel_length/2))} 0.0" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="right_wheel_link"/>
        <axis xyz="0.0 1.0 0.0"/>
    </joint>

    <joint name="caster_wheel_joint" type="fixed">
        <origin xyz="${base_length/3} 0.0 ${-caster_radius}" rpy="0.0 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="caster_wheel_link"/>
    </joint>

</robot>
